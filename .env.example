# === Required ===
API_KEY=your_api_key_here

# === API Server ===
BASE_URL=http://localhost:8080

# === Callback Server (required for async callback tests) ===
# Expose CALLBACK_PORT via ngrok or Cloudflare Tunnel, then set PUBLIC_URL to the tunnel address
PUBLIC_URL=https://your-tunnel-url.example.com
# CALLBACK_PORT=3456

# === Timeouts (seconds) ===
# SYNC_TIMEOUT=60     # /uploadimage, /imageurl (synchronous OCR — needs more time)
# ASYNC_TIMEOUT=30    # /async-callback, /tasks  (just submitting/querying)
# CALLBACK_WAIT=120   # max wait for OCR server to POST callback back

# === Image ===
# IMAGE_PATH=image/example.jpg
